APP_ENV=development
# Local default: SQLite requires no Docker or extra service.
DATABASE_URL=sqlite:///./travel_planner.db
# Production option: postgresql+psycopg://user:password@host:5432/travel_planner
CORS_ORIGINS=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
PRESET_USER_EMAIL=demo@travel-planner.example.com
PRESET_USER_PASSWORD=change-this-development-password
AMAP_WEB_SERVICE_KEY=
AMAP_WEB_SERVICE_BASE_URL=https://restapi.amap.com
